{
    "name": "dandoetech/laravel-resource-registry",
    "description": "Laravel bridge for DanDoeTech Resource Registry: ClassBasedDriver, capability interfaces, computed resolvers, ServiceProvider.",
    "type": "library",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "license": "MIT",
    "authors": [
        {
            "name": "Danilo Doelle",
            "email": "oss@dandoe.tech"
        }
    ],
    "homepage": "https://github.com/dandoetech/laravel-resource-registry",
    "keywords": [
        "php",
        "laravel",
        "registry",
        "resource",
        "eloquent",
        "crud"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/config": "^11.0 || ^12.0",
        "illuminate/database": "^11.0 || ^12.0",
        "dandoetech/resource-registry": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "DanDoeTech\\LaravelResourceRegistry\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DanDoeTech\\LaravelResourceRegistry\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0",
        "orchestra/testbench": "^9.0 || ^10.0"
    },
    "scripts": {
        "test": "XDEBUG_MODE=off phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text --coverage-clover=coverage/clover.xml",
        "cs:fix": "php-cs-fixer fix --allow-risky=yes",
        "cs:check": "php-cs-fixer fix --allow-risky=yes --dry-run",
        "stan": "phpstan analyse --memory-limit=1G",
        "qa": [
            "@cs:check",
            "@stan",
            "@test"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "laravel": {
            "providers": [
                "DanDoeTech\\LaravelResourceRegistry\\DdtServiceProvider"
            ]
        }
    }
}
